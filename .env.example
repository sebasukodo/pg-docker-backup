# --- Required configuration ---

# Encryption Key for securing backups
# Must be set (otherwise backup will fail)
# Generate with: openssl rand -base64 32
ENCRYPT_KEY=

# --- Required configuration for run-backup.sh ---

# Local directory where backups will be stored
# If not set, the script will fallback to current directory
BACKUP_FOLDER_PATH=/mnt/pg-backups

# Docker container name running PostgreSQL
CONTAINER_NAME=postgres-container

# Database Configuration
DB_NAME=mydb
DB_USER=postgres
DB_PASSWORD=secret

# --- Optional configuration for run-backup.sh ---

# Enable remote backup via rsync over SSH by setting BOTH variables below

# SSH destination (format: user@host or host if SSH config is set up)
RSYNC_DEST_HOST=user@127.0.0.1

# Remote directory where backups from BACKUP_FOLDER_PATH will be stored
RSYNC_DEST_DIR=/home/user/backups
